# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# typescript
*.tsbuildinfo
next-env.d.ts.bak

# vercel
.vercel

# data — SQLite db, WAL/SHM sidecars, backups; all runtime-only
/data/

# local-only experiments — files ending in .local.ts / .local.test.ts stay
# out of git. Useful for AI provider variants, scratch scripts, etc.
*.local.ts
*.local.test.ts

# browser-automation screenshots (agent-browser / playwright-cli) — throwaway
/.playwright-cli/

# Claude Code agent worktrees — ephemeral, machine-local scratch
/.claude/worktrees/

# next.js auto-generated, regenerated on every build
next-env.d.ts
