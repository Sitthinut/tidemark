# Tidemark — operator config. Copy to `.env.local` and fill what you need.
# `.env.local` is gitignored; commit only this template.

# ─── App URL ───────────────────────────────────────────────────────────────
# Used for OpenRouter referer + WebAuthn passkey origin in production.
# In dev, http://localhost:3000 is always trusted.
PUBLIC_APP_URL=http://localhost:3000

# ─── Auth (better-auth + passkey) ──────────────────────────────────────────
# Set to "1" to require passkey login before the dashboard renders.
# When unset, the app behaves like before — open access, single user.
# AUTH_REQUIRED=1

# Generate with `openssl rand -base64 32`. Required when AUTH_REQUIRED=1.
# AUTH_SECRET=

# Optional — Relying Party config. Defaults: rpName="Tidemark", rpID inferred
# from PUBLIC_APP_URL host. Override only if you understand WebAuthn rpID rules.
# AUTH_RP_NAME=Tidemark
# AUTH_RP_ID=tidemark.example.com

# ─── AI provider (OpenRouter) ──────────────────────────────────────────────
# Tidemark routes all chat through OpenRouter (one key, every major model).
# Sign up at https://openrouter.ai to get a key; pricing is per-token credit.
#
# OPENROUTER_API_KEY=sk-or-...
#
# Model chain (comma-separated, first is primary, rest are fallbacks).
# Default: `openrouter/free,openrouter/auto` — try free models first, fall
# back to paid `auto` only if every free model is unavailable. Override with
# any model id from openrouter.ai/models (e.g. `anthropic/claude-sonnet-4.5`).
# AI_MODELS=openrouter/free,openrouter/auto

# ─── AI provider (demo-side) ───────────────────────────────────────────────
# Demo chat is routed through a separate key so demo usage can never burn
# your owner key's quota. Capped at 10 turns per demo session.
#
# Easiest setup: leave DEMO_OPENROUTER_API_KEY unset — demo falls back to
# OPENROUTER_API_KEY, and the default `openrouter/free` (no paid fallback)
# picks zero-cost models per request. Demo errors cleanly if free is
# unavailable rather than silently billing.
#
# For stricter isolation, create a second OpenRouter key and set:
# DEMO_OPENROUTER_API_KEY=sk-or-...
# DEMO_AI_MODELS=openrouter/free                          # default; no fallback
# DEMO_AI_MODELS=meta-llama/llama-3.3-70b-instruct:free   # pin a specific one

# ─── Database ──────────────────────────────────────────────────────────────
# Path to the SQLite file. Default: data/app.db (auto-created).
# DB_PATH=data/app.db
